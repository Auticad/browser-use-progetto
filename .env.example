# .env.example — Copia questo file in .env e inserisci le tue chiavi reali.
# Il file .env NON deve mai essere committato (è già in .gitignore).

# ── Chiavi API (almeno una obbligatoria) ─────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Parametri agente (opzionali — valori di default mostrati) ────────────────
DEFAULT_MODEL=gpt-4o
DEFAULT_MAX_STEPS=30
DEFAULT_MAX_ACTIONS_PER_STEP=5
